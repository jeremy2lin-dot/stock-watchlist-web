WATCHLIST_DATA_PATH=watchlist_data.json
WATCHLIST_EXPORT_DIR=exports
WATCHLIST_BACKUP_DIR=backups
WATCHLIST_MAX_BACKUPS=50
WATCHLIST_USER=your_login_name
WATCHLIST_PASSWORD=your_strong_password

# Mega Speedy quote API. Only works on a Windows machine with the Mega Speedy
# Python SDK installed. Render/Linux should keep these blank and use TWSE/TPEX.
MEGA_QUOTE_HOST=
MEGA_QUOTE_PORT=34567
MEGA_QUOTE_ID=
MEGA_QUOTE_PASSWORD=
MEGA_QUOTE_DOWNLOAD_CONTRACTS=0
MEGA_QUOTE_TIMEOUT=8
